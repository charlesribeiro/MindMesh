# Frontend (Vite)
VITE_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

# Set to "true" to intercept GraphQL with MSW in the browser (failure scenarios).
# Leave unset/false for the real local GraphQL Yoga API during normal development.
# VITE_USE_MOCK_API=true

# API
# PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Required in production. Safe development fallback exists when NODE_ENV !== 'production'.
# JWT_SECRET=replace-with-a-long-random-secret
